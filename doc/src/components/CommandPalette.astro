---
/**
 * Busca global (Ctrl/⌘ K) sobre toda a base: origens, encantamentos, recursos,
 * compatibilidade e páginas. O índice é montado no build e navegado por teclado.
 */
import Icon from './Icon.astro';
import { origins, originCode } from '../data/origins';
import { enchantments, enchantCode } from '../data/enchantments';
import { features, featureCode } from '../data/features';
import { compatItems, compatCode } from '../data/compat';

type Entry = { code: string; title: string; sub: string; type: string; url: string; kw: string };

const index: Entry[] = [
  ...origins.map((o) => ({
    code: originCode(o),
    title: o.name,
    sub: `${o.group} · ${o.diet}`,
    type: 'Origem',
    url: `/origins/${o.slug}`,
    kw: `${o.name} ${o.group} ${o.category} ${o.playstyle} ${o.diet} ${o.pros.join(' ')} ${o.cons.join(' ')}`.toLowerCase(),
  })),
  ...enchantments.map((e) => ({
    code: enchantCode(e),
    title: e.name,
    sub: e.original,
    type: 'Encantamento',
    url: `/wiki/encantamentos#${e.slug}`,
    kw: `${e.name} ${e.original} ${e.desc} ${e.serve} ${e.items}`.toLowerCase(),
  })),
  ...features.map((f) => ({
    code: featureCode(f),
    title: f.name,
    sub: f.command ?? f.plugin ?? 'Recurso',
    type: 'Recurso',
    url: `/wiki/recursos#${f.slug}`,
    kw: `${f.name} ${f.command ?? ''} ${f.desc} ${f.plugin ?? ''}`.toLowerCase(),
  })),
  ...compatItems.map((i) => ({
    code: compatCode(i),
    title: i.name,
    sub: i.status,
    type: 'Compatibilidade',
    url: `/wiki/compatibilidade#${i.slug}`,
    kw: `${i.name} ${i.desc} ${i.status}`.toLowerCase(),
  })),
  { code: 'FF-PG-00', title: 'Início', sub: 'Visão geral e conexão', type: 'Página', url: '/', kw: 'inicio home conectar ip java bedrock servidor' },
  { code: 'FF-PG-01', title: 'Wiki', sub: 'Índice da base', type: 'Página', url: '/wiki', kw: 'wiki indice guia' },
  { code: 'FF-PG-05', title: 'Changelog', sub: 'Histórico de versões', type: 'Página', url: '/changelog', kw: 'changelog versoes historico mudancas' },
];

const data = JSON.stringify(index).replace(/</g, '\\u003c');
---

<div class="cmdk-overlay" id="cmdk" hidden>
  <div class="cmdk-backdrop" data-close></div>
  <div class="cmdk-panel" role="dialog" aria-modal="true" aria-label="Buscar na documentação">
    <div class="cmdk-input">
      <Icon name="search" size={17} />
      <input
        id="cmdk-input"
        type="text"
        placeholder="Buscar origens, encantamentos, recursos…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Buscar na documentação"
      />
      <span class="kbd">ESC</span>
    </div>
    <div class="cmdk-results" id="cmdk-results" role="listbox" aria-label="Resultados"></div>
    <div class="cmdk-foot">
      <span><span class="kbd">↑</span><span class="kbd">↓</span> navegar</span>
      <span><span class="kbd">↵</span> abrir</span>
      <span class="brand">Feather Flux · Knowledge Base</span>
    </div>
  </div>
</div>

<script type="application/json" id="cmdk-data" set:html={data}></script>


<script>
  type Entry = { code: string; title: string; sub: string; type: string; url: string; kw: string };

  const overlay = document.getElementById('cmdk');
  const input = document.getElementById('cmdk-input') as HTMLInputElement | null;
  const results = document.getElementById('cmdk-results');
  const dataEl = document.getElementById('cmdk-data');
  const root = document.documentElement;

  if (overlay && input && results && dataEl) {
    const index: Entry[] = JSON.parse(dataEl.textContent || '[]');
    let rows: Entry[] = [];
    let sel = 0;

    const open = () => {
      overlay.hidden = false;
      root.style.overflow = 'hidden';
      input.value = '';
      render('');
      requestAnimationFrame(() => input.focus());
    };
    const close = () => {
      overlay.hidden = true;
      root.style.overflow = '';
    };

    const score = (e: Entry, q: string): number => {
      if (!q) return 1;
      const t = e.title.toLowerCase();
      const c = e.code.toLowerCase();
      if (t === q || c === q) return 100;
      if (t.startsWith(q)) return 80;
      if (c.includes(q)) return 70;
      if (t.includes(q)) return 60;
      if (e.sub.toLowerCase().includes(q)) return 40;
      if (e.kw.includes(q)) return 20;
      return 0;
    };

    const render = (raw: string) => {
      const q = raw.trim().toLowerCase();
      rows = (q
        ? index
            .map((e) => ({ e, s: score(e, q) }))
            .filter((x) => x.s > 0)
            .sort((a, b) => b.s - a.s)
            .map((x) => x.e)
        : index.filter((e) => e.type === 'Página' || e.type === 'Origem').slice(0, 8)
      ).slice(0, 40);
      sel = 0;

      if (!rows.length) {
        results.innerHTML = '<div class="cmdk-empty">Nada encontrado. Tente outra palavra.</div>';
        return;
      }

      let html = '';
      let lastType = '';
      rows.forEach((e, i) => {
        if (e.type !== lastType) {
          html += `<div class="cmdk-group">${e.type}</div>`;
          lastType = e.type;
        }
        html += `<a class="cmdk-res" role="option" data-i="${i}" href="${e.url}" aria-selected="${i === 0}">`
          + `<span class="cmdk-code">${e.code}</span>`
          + `<span class="cmdk-main"><b>${esc(e.title)}</b><span>${esc(e.sub)}</span></span>`
          + `<span class="cmdk-type">${e.type}</span></a>`;
      });
      results.innerHTML = html;
    };

    const esc = (s: string) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

    const highlight = () => {
      const opts = [...results.querySelectorAll<HTMLElement>('.cmdk-res')];
      opts.forEach((o, i) => o.setAttribute('aria-selected', String(i === sel)));
      opts[sel]?.scrollIntoView({ block: 'nearest' });
    };

    const go = () => {
      const url = rows[sel]?.url;
      if (url) window.location.href = url;
    };

    input.addEventListener('input', () => render(input.value));
    results.addEventListener('mousemove', (e) => {
      const r = (e.target as HTMLElement).closest('.cmdk-res') as HTMLElement | null;
      if (r) {
        sel = Number(r.dataset.i);
        highlight();
      }
    });

    overlay.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        sel = Math.min(sel + 1, rows.length - 1);
        highlight();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        sel = Math.max(sel - 1, 0);
        highlight();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        go();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        close();
      }
    });

    overlay.querySelector('[data-close]')?.addEventListener('click', close);
    document.getElementById('cmdk-open')?.addEventListener('click', open);
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        overlay.hidden ? open() : close();
      }
    });
  }
</script>
