---
/**
 * Índice fixo (sidebar) — o centro da navegação, no formato do sumário de um
 * manual técnico: marca, metadados (versão/build/status) e a árvore de seções
 * (Wiki e suas subseções aninhadas).
 */
import Icon from './Icon.astro';
import { site } from '../data/site';

const path = (Astro.url.pathname.replace(/\/+$/, '') || '/');

const isActive = (href: string) => {
  if (href === '/') return path === '/';
  if (href === '/wiki') return path === '/wiki';
  if (href === '/wiki/origens') return path === '/wiki/origens' || path.startsWith('/origins');
  return path === href || path.startsWith(href + '/');
};

// Seções da Wiki, aninhadas sob o item "Wiki" como uma árvore de documentação.
const wikiChildren = [
  { label: 'Origens', href: '/wiki/origens' },
  { label: 'Encantamentos', href: '/wiki/encantamentos' },
  { label: 'Recursos', href: '/wiki/recursos' },
  { label: 'Compatibilidade', href: '/wiki/compatibilidade' },
];

const wikiOpen = path === '/wiki' || path.startsWith('/wiki/') || path.startsWith('/origins');
---

<aside class="sidebar" id="sidebar" aria-label="Índice da documentação">
  <div class="sb-inner">
    <a href="/" class="brand" aria-label={`${site.name}, início`}>
      <span class="brand-mark"><Icon name="feather" size={17} /></span>
      <span class="brand-text">
        <b>{site.name}</b>
        <span class="brand-sub">Knowledge Base</span>
      </span>
    </a>

    <div class="meta">
      <span>v{site.meta.version}</span>
      <span class="sep">/</span>
      <span>build {site.meta.build}</span>
      <span class="status"><i class="dot"></i>{site.meta.status}</span>
    </div>

    <nav class="nav" aria-label="Seções">
      <ul class="grp">
        <li>
          <a href="/" class:list={['nav-item', { active: isActive('/') }]} aria-current={isActive('/') ? 'page' : undefined}>
            <span class="ico"><Icon name="home" size={15} /></span>
            <span class="lbl">Início</span>
          </a>
        </li>

        <li>
          <a href="/wiki" class:list={['nav-item', { active: isActive('/wiki'), open: wikiOpen }]} aria-current={isActive('/wiki') ? 'page' : undefined}>
            <span class="ico"><Icon name="book" size={15} /></span>
            <span class="lbl">Wiki</span>
          </a>
          <ul class="subtree">
            {
              wikiChildren.map((c) => (
                <li>
                  <a href={c.href} class:list={['nav-item', 'sub', { active: isActive(c.href) }]} aria-current={isActive(c.href) ? 'page' : undefined}>
                    <span class="lbl">{c.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </li>

        <li>
          <a href="/changelog" class:list={['nav-item', { active: isActive('/changelog') }]} aria-current={isActive('/changelog') ? 'page' : undefined}>
            <span class="ico"><Icon name="gauge" size={15} /></span>
            <span class="lbl">Changelog</span>
          </a>
        </li>

        <li>
          <a href={site.discord} class="nav-item" target="_blank" rel="noopener">
            <span class="ico"><Icon name="discord" size={15} /></span>
            <span class="lbl">Discord</span>
            <Icon name="external" size={13} />
          </a>
        </li>
      </ul>
    </nav>
  </div>
</aside>

<style>
  .sidebar {
    grid-row: 1;
    grid-column: 1;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    background: var(--panel);
    z-index: 75;
  }
  .sb-inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 1.15rem 0.9rem 1rem;
  }

  /* ---- Brand ---- */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.3rem 0.45rem 0.9rem;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    flex: none;
    color: var(--gold);
    border: 1px solid var(--gold-dim);
    background: var(--bg);
  }
  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .brand-text b {
    font-weight: 600;
    font-size: 0.96rem;
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-top: 0.12rem;
  }

  /* ---- Meta line ---- */
  .meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0.55rem 0.5rem;
    margin: 0 0.1rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.02em;
    color: var(--text-faint);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .meta .sep {
    color: var(--text-mute);
  }
  .meta .status {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    color: var(--text-dim);
  }
  .meta .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
  }

  /* ---- Nav ---- */
  .nav {
    flex: 1;
  }
  .grp {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.46rem 0.55rem;
    color: var(--text-dim);
    border-left: 2px solid transparent;
    transition:
      color var(--t),
      background var(--t),
      border-color var(--t);
  }
  .nav-item .lbl {
    font-size: 0.875rem;
    font-weight: 450;
  }
  .nav-item .ico {
    display: inline-flex;
    width: 1.05rem;
    justify-content: center;
    color: var(--text-faint);
    transition: color var(--t);
  }
  .nav-item > :global(svg:last-child) {
    margin-left: auto;
    color: var(--text-mute);
  }
  .nav-item:hover {
    color: var(--text);
    background: var(--panel-2);
  }
  .nav-item:hover .ico {
    color: var(--text-dim);
  }
  .nav-item.active {
    color: var(--text);
    border-left-color: var(--gold);
    background: var(--panel-2);
  }
  .nav-item.active .ico {
    color: var(--gold);
  }
  .nav-item.active .lbl {
    font-weight: 550;
  }
  /* "Wiki" enquanto você está em alguma subseção. */
  .nav-item.open:not(.active) {
    color: var(--text);
  }
  .nav-item.open:not(.active) .ico {
    color: var(--text-dim);
  }

  /* ---- Wiki subtree (árvore) ---- */
  .subtree {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin: 1px 0 1px 1.15rem;
    border-left: 1px solid var(--line);
  }
  .nav-item.sub {
    margin-left: -1px;
    padding: 0.38rem 0.55rem 0.38rem 0.95rem;
  }
  .nav-item.sub .lbl {
    font-size: 0.84rem;
  }

  /* ---- Off-canvas on small screens ---- */
  @media (max-width: 900px) {
    .sidebar {
      position: fixed;
      inset: 0 auto 0 0;
      width: min(85vw, 300px);
      border-right: 1px solid var(--line-2);
      transform: translateX(-100%);
      transition: transform 0.18s ease;
    }
    :global(html[data-nav-open]) .sidebar {
      transform: none;
    }
  }
</style>
