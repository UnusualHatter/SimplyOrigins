---
import Stars from './Stars.astro';
import { originCode, type Origin } from '../data/origins';

interface Props {
  origin: Origin;
  /** Texto extra para a busca da Wiki (poderes, fraquezas etc.). */
  search?: string;
}
const { origin, search } = Astro.props;
const code = originCode(origin);
---

<a
  href={`/origins/${origin.slug}`}
  class="origin-card"
  data-group={origin.group}
  data-search={search}
>
  <div class="oc-top">
    <span class="oc-code">{code}</span>
    <Stars value={origin.difficulty} />
  </div>
  <div class="oc-id">
    <span class="oc-glyph" aria-hidden="true">{origin.emoji}</span>
    <span class="oc-names">
      <h3>{origin.name}</h3>
      <span class="oc-sub">{origin.group} · {origin.diet}</span>
    </span>
  </div>
  <p class="oc-tagline">{origin.tagline}</p>
  <span class="oc-open">Abrir documentação <span class="arr">→</span></span>
</a>

<style>
  .origin-card {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1rem 1.05rem 0.9rem;
    background: var(--panel);
    border: 1px solid var(--line);
    transition:
      border-color var(--t),
      background var(--t);
  }
  .origin-card:hover {
    border-color: var(--gold);
    background: var(--panel-2);
  }

  .oc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .oc-code {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    color: var(--text-faint);
  }

  .oc-id {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .oc-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex: none;
    font-size: 1.25rem;
    border: 1px solid var(--line-2);
    background: var(--bg);
  }
  .oc-names {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .oc-names h3 {
    font-size: 1.08rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .oc-sub {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.02em;
    color: var(--text-faint);
  }

  .oc-tagline {
    flex: 1;
    color: var(--text-dim);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .oc-open {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.7rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-faint);
    transition: color var(--t);
  }
  .origin-card:hover .oc-open {
    color: var(--gold-bright);
  }
  .oc-open .arr {
    transition: transform var(--t);
  }
</style>
