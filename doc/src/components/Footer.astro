---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container foot">
    <div class="foot-meta">
      <span class="foot-brand">{site.name}</span>
      <span class="sep">/</span>
      <span>Knowledge Base</span>
      <span class="sep">/</span>
      <span>v{site.meta.version}</span>
    </div>
    <nav class="foot-nav" aria-label="Rodapé">
      <a href="/wiki/origens">Origens</a>
      <a href="/wiki/encantamentos">Encantamentos</a>
      <a href="/changelog">Changelog</a>
      <a href={site.discord} target="_blank" rel="noopener">Discord</a>
    </nav>
  </div>
  <div class="container fine">
    <span>© {year} {site.name}. Não afiliado à Mojang ou Microsoft.</span>
    <span>Documentação do servidor</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--line);
    padding-block: 1.5rem 1.75rem;
  }
  .foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem 1.5rem;
  }
  .foot-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
  }
  .foot-meta .foot-brand {
    color: var(--text-dim);
  }
  .foot-meta .sep {
    color: var(--text-mute);
  }
  .foot-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem;
  }
  .foot-nav a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--text-faint);
    transition: color var(--t);
  }
  .foot-nav a:hover {
    color: var(--gold-bright);
  }
  .fine {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.4rem 1.5rem;
    margin-top: 1.1rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--text-mute);
  }
</style>
