---
/** Navegação entre as seções da Wiki — barra de abas sublinhadas. */
interface Props {
  active: 'origens' | 'encantamentos' | 'recursos' | 'compatibilidade';
}
const { active } = Astro.props;

const tabs = [
  { key: 'origens', n: '01', label: 'Origens', href: '/wiki/origens' },
  { key: 'encantamentos', n: '02', label: 'Encantamentos', href: '/wiki/encantamentos' },
  { key: 'recursos', n: '03', label: 'Recursos', href: '/wiki/recursos' },
  { key: 'compatibilidade', n: '04', label: 'Compatibilidade', href: '/wiki/compatibilidade' },
] as const;
---

<nav class="wiki-tabs" aria-label="Seções da Wiki">
  {
    tabs.map((t) => (
      <a
        href={t.href}
        class:list={['wtab', { active: t.key === active }]}
        aria-current={t.key === active ? 'page' : undefined}
      >
        <span class="n">{t.n}</span>
        {t.label}
      </a>
    ))
  }
</nav>

<style>
  .wiki-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.1rem 1.5rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: clamp(1.5rem, 4vw, 2.25rem);
  }
  .wtab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.1rem;
    font-size: 0.88rem;
    font-weight: 450;
    color: var(--text-faint);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition:
      color var(--t),
      border-color var(--t);
  }
  .wtab .n {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--text-mute);
    transition: color var(--t);
  }
  .wtab:hover {
    color: var(--text);
  }
  .wtab.active {
    color: var(--text);
    border-bottom-color: var(--gold);
    font-weight: 550;
  }
  .wtab.active .n {
    color: var(--gold);
  }
</style>
