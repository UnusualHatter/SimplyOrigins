---
/** Indicador de dificuldade 1–5 em caracteres monoespaçados. <Stars value={3} /> */
interface Props {
  value: number;
  max?: number;
}
const { value, max = 5 } = Astro.props;
const filled = '★'.repeat(value);
const empty = '☆'.repeat(Math.max(0, max - value));
---

<span class="stars" role="img" aria-label={`Dificuldade ${value} de ${max}`}>
  <span class="on">{filled}</span><span class="off">{empty}</span>
</span>

<style>
  .stars {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
  }
  .on {
    color: var(--gold);
  }
  .off {
    color: var(--text-mute);
  }
</style>
