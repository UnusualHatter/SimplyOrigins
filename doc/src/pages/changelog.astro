---
import Base from '../layouts/Base.astro';
import { changelog } from '../data/changelog';

const sections = [
  { key: 'added' as const, label: 'Adicionado', cls: 'added' },
  { key: 'changed' as const, label: 'Modificado', cls: 'changed' },
  { key: 'fixed' as const, label: 'Corrigido', cls: 'fixed' },
];

const fmtDate = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });

// Preview de redes sociais: usa o ÚLTIMO changelog (summary ou gerado das listas).
const latest = changelog[0];
const bullets = (arr?: string[]) => (arr && arr.length ? arr.map((x) => '• ' + x).join('\n') : '');
const autoSummary = [
  latest.added && 'Adicionado:\n' + bullets(latest.added),
  latest.changed && 'Modificado:\n' + bullets(latest.changed),
  latest.fixed && 'Corrigido:\n' + bullets(latest.fixed),
]
  .filter(Boolean)
  .join('\n');
const ogDescription = latest.summary ?? autoSummary;
---

<Base title={`Changelog v${latest.version}`} description={ogDescription}>
  <div class="container">
    <header class="doc-head">
      <span class="eyebrow">Knowledge Base</span>
      <h1>Changelog</h1>
      <p class="lead">
        Registro técnico do que foi adicionado, modificado e corrigido no plugin a cada versão.
      </p>
    </header>

    <div class="log">
      {
        changelog.map((entry) => (
          <article class="entry">
            <header class="entry-head">
              <span class="ver">v{entry.version}</span>
              <time datetime={entry.date}>{fmtDate(entry.date)}</time>
            </header>
            <div class="entry-body">
              {sections.map((s) =>
                entry[s.key] && entry[s.key]!.length > 0 ? (
                  <div class:list={['group', s.cls]}>
                    <h2>{s.label}</h2>
                    <ul>
                      {entry[s.key]!.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                ) : null
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</Base>

<style>
  .log {
    max-width: 820px;
  }
  .entry {
    border-top: 1px solid var(--line-2);
    padding: 1.4rem 0 1.6rem;
  }
  .entry:first-child {
    border-top: 0;
  }
  .entry-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.3rem;
  }
  .ver {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--gold-bright);
    letter-spacing: -0.01em;
  }
  .entry-head time {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-faint);
    margin-left: auto;
  }
  .entry-body {
    display: grid;
    gap: 1.5rem;
  }
  .group {
    display: grid;
    grid-template-columns: 8.5rem 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  .group h2 {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-top: 0.2rem;
  }
  .group.added h2 {
    color: var(--green);
  }
  .group.changed h2 {
    color: var(--gold);
  }
  .group.fixed h2 {
    color: var(--red);
  }
  .group ul {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .group li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-dim);
    font-size: 0.92rem;
    line-height: 1.6;
  }
  .group li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
  }
  .group.added li::before {
    background: var(--green);
  }
  .group.changed li::before {
    background: var(--gold);
  }
  .group.fixed li::before {
    background: var(--red);
  }

  @media (max-width: 600px) {
    .group {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }
  }
</style>
