---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import { changelog } from '../data/changelog';

const sections = [
  { key: 'added' as const, label: 'Adicionado', cls: 'added' },
  { key: 'changed' as const, label: 'Modificado', cls: 'changed' },
  { key: 'fixed' as const, label: 'Corrigido', cls: 'fixed' },
];

const fmtDate = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('pt-BR', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  });
---

<Base
  title="Changelog"
  description="Histórico técnico de alterações do plugin Feather Flux: adições, modificações e correções por versão."
>
  <section class="container intro">
    <span class="eyebrow"><Icon name="gauge" size={15} /> Histórico técnico</span>
    <h1 class="section-title">Changelog</h1>
    <p class="section-sub">Registro objetivo do que foi adicionado, modificado e corrigido no plugin a cada versão.</p>
  </section>

  <section class="container log">
    {
      changelog.map((entry) => (
        <article class="entry card">
          <header class="entry-head">
            <h2>v{entry.version}</h2>
            <time datetime={entry.date}>{fmtDate(entry.date)}</time>
          </header>
          {
            sections.map((s) =>
              entry[s.key] && entry[s.key]!.length > 0 ? (
                <div class:list={['group', s.cls]}>
                  <h3>{s.label}</h3>
                  <ul>
                    {entry[s.key]!.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              ) : null
            )
          }
        </article>
      ))
    }
  </section>
</Base>

<style>
  .intro {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }
  .intro .section-sub {
    margin-inline: auto;
  }
  .log {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    max-width: 820px;
  }
  .entry {
    padding: clamp(1.3rem, 3.5vw, 2rem);
  }
  .entry-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.9rem;
    margin-bottom: 1.2rem;
    border-bottom: 1px solid var(--border);
  }
  .entry-head h2 {
    font-size: 1.6rem;
    color: var(--gold-bright);
  }
  .entry-head time {
    color: var(--text-faint);
    font-size: 0.88rem;
  }
  .group {
    margin-bottom: 1.2rem;
  }
  .group:last-child {
    margin-bottom: 0;
  }
  .group h3 {
    font-family: var(--font-body);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.7rem;
  }
  .group.added h3 {
    color: var(--green);
  }
  .group.changed h3 {
    color: var(--gold);
  }
  .group.fixed h3 {
    color: var(--coral);
  }
  .group ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .group li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .group li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.5;
  }
  .group.added li::before {
    background: var(--green);
  }
  .group.changed li::before {
    background: var(--gold);
  }
  .group.fixed li::before {
    background: var(--coral);
  }
</style>
