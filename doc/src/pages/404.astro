---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
---

<Base title="Página não encontrada" description="A página que você procura não existe.">
  <div class="container nf">
    <span class="eyebrow">Erro / HTTP 404</span>
    <span class="code">404</span>
    <h1>Recurso não encontrado</h1>
    <p>A página que você procura não existe ou foi movida. Use a busca (Ctrl K) ou volte ao índice.</p>
    <div class="actions">
      <a class="btn btn-primary" href="/"><Icon name="arrow-left" size={14} /> Início</a>
      <a class="btn" href="/wiki/origens">Ver origens</a>
    </div>
  </div>
</Base>

<style>
  .nf {
    padding-block: clamp(2.5rem, 8vw, 5rem);
    max-width: 60ch;
  }
  .code {
    display: block;
    font-family: var(--font-mono);
    font-size: clamp(4rem, 15vw, 7rem);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 1rem 0 0.75rem;
  }
  .nf h1 {
    font-size: clamp(1.4rem, 4vw, 2rem);
  }
  .nf p {
    color: var(--text-dim);
    margin-top: 0.75rem;
    line-height: 1.6;
  }
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.75rem;
  }
</style>
