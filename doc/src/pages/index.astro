---
import Base from '../layouts/Base.astro';
import { origins } from '../data/origins';
import { enchantmentCount } from '../data/enchantments';
import { featureCount } from '../data/features';
import { compatCount } from '../data/compat';
import { site } from '../data/site';

const conn = [
  { ed: 'Java', label: 'IP principal', value: site.connect.java.main },
  { ed: 'Java', label: 'IP secundário', value: site.connect.java.secondary },
  { ed: 'Bedrock', label: 'IP', value: site.connect.bedrock.ip },
  { ed: 'Bedrock', label: 'Porta', value: String(site.connect.bedrock.port) },
];

const toc = [
  { n: '01', name: 'Origens', count: `${origins.length}`, href: '/wiki/origens', desc: 'As 16 origens jogáveis: poderes, fraquezas e progressão própria do nível 1 ao 10.' },
  { n: '02', name: 'Encantamentos', count: `${enchantmentCount}`, href: '/wiki/encantamentos', desc: 'Encantos personalizados além dos do Minecraft: o que faz, pra que serve e onde achar.' },
  { n: '03', name: 'Recursos', count: `${featureCount}`, href: '/wiki/recursos', desc: 'Comandos e funcionalidades: casa, teleporte, viagem rápida, lápides, mídia.' },
  { n: '04', name: 'Compatibilidade', count: `${compatCount}`, href: '/wiki/compatibilidade', desc: 'Mods client-side suportados, edições e versões para montar seu modpack.' },
  { n: '05', name: 'Changelog', count: '—', href: '/changelog', desc: 'Registro técnico do que foi adicionado, alterado e corrigido a cada versão.' },
];
---

<Base>
  <div class="container">
    <header class="doc-head">
      <span class="eyebrow">Knowledge Base / Visão geral</span>
      <h1>Feather Flux</h1>
      <p class="lead">{site.description}</p>
      <div class="spec">
        <span class="tag">Origins SMP</span>
        <span class="tag">Java + Bedrock</span>
        <span class="tag">v{site.meta.version}</span>
        <span class="tag">Build {site.meta.build}</span>
      </div>
    </header>

    <!-- Conexão -->
    <section class="section-label">
      <span class="sq"></span>
      <h2>Conexão</h2>
      <span class="count">Entre e escolha sua origem</span>
    </section>

    <div class="conn panel">
      {
        conn.map((c) => (
          <div class="conn-row">
            <span class="conn-ed">{c.ed}</span>
            <span class="conn-label">{c.label}</span>
            <code class="conn-val">{c.value}</code>
            <button class="copy-btn" type="button" data-copy={c.value} aria-label={`Copiar ${c.ed} ${c.label}`}>
              <span class="copy-text">Copiar</span>
            </button>
          </div>
        ))
      }
    </div>
    <p class="conn-note">
      Já tem o jogo? Use o endereço da sua edição no Minecraft. É a primeira vez?
      <a href={site.discord} target="_blank" rel="noopener">Entre no Discord</a> para tirar dúvidas.
    </p>

    <!-- Índice -->
    <section class="section-label">
      <span class="sq"></span>
      <h2>Índice da base</h2>
      <span class="count">{toc.length} seções</span>
    </section>

    <nav class="toc" aria-label="Seções da documentação">
      {
        toc.map((t) => (
          <a class="toc-row" href={t.href}>
            <span class="toc-n">{t.n}</span>
            <span class="toc-name">{t.name}</span>
            <span class="toc-count">{t.count}</span>
            <span class="toc-desc">{t.desc}</span>
            <span class="toc-arr">→</span>
          </a>
        ))
      }
    </nav>
  </div>
</Base>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const val = btn.getAttribute('data-copy');
      if (!val) return;
      try {
        await navigator.clipboard.writeText(val.trim());
        const label = btn.querySelector('.copy-text');
        if (label) {
          const prev = label.textContent;
          label.textContent = 'Copiado';
          btn.classList.add('done');
          setTimeout(() => {
            label.textContent = prev;
            btn.classList.remove('done');
          }, 1500);
        }
      } catch {
        /* clipboard indisponível */
      }
    });
  });
</script>

<style>
  .spec {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1.3rem;
  }

  /* ---- Conexão ---- */
  .conn {
    display: flex;
    flex-direction: column;
  }
  .conn-row {
    display: grid;
    grid-template-columns: 5.5rem 8rem 1fr auto;
    align-items: center;
    gap: 0.9rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--line);
  }
  .conn-row:last-child {
    border-bottom: 0;
  }
  .conn-ed {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .conn-label {
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .conn-val {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--gold-bright);
    overflow-wrap: anywhere;
  }
  .copy-btn {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
    background: transparent;
    border: 1px solid var(--line-2);
    padding: 0.35rem 0.6rem;
    cursor: pointer;
    transition:
      color var(--t),
      border-color var(--t);
  }
  .copy-btn:hover {
    color: var(--text);
    border-color: var(--line-3);
  }
  .copy-btn.done {
    color: var(--green);
    border-color: color-mix(in srgb, var(--green) 50%, transparent);
  }
  .conn-note {
    margin-top: 0.9rem;
    font-size: 0.84rem;
    color: var(--text-faint);
  }
  .conn-note a {
    color: var(--gold-bright);
  }
  .conn-note a:hover {
    text-decoration: underline;
  }

  /* ---- Índice (TOC) ---- */
  .toc {
    border: 1px solid var(--line);
  }
  .toc-row {
    display: grid;
    grid-template-columns: 2rem 11rem 3rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.95rem 1.1rem;
    border-bottom: 1px solid var(--line);
    border-left: 2px solid transparent;
    transition:
      background var(--t),
      border-color var(--t);
  }
  .toc-row:last-child {
    border-bottom: 0;
  }
  .toc-row:hover {
    background: var(--panel-2);
    border-left-color: var(--gold);
  }
  .toc-n {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-mute);
  }
  .toc-row:hover .toc-n {
    color: var(--gold);
  }
  .toc-name {
    font-size: 0.98rem;
    font-weight: 550;
  }
  .toc-count {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-faint);
    text-align: right;
  }
  .toc-desc {
    font-size: 0.84rem;
    color: var(--text-dim);
    line-height: 1.45;
  }
  .toc-arr {
    font-family: var(--font-mono);
    color: var(--text-mute);
  }
  .toc-row:hover .toc-arr {
    color: var(--gold-bright);
  }

  @media (max-width: 720px) {
    .conn-row {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        'ed ed'
        'label copy'
        'val val';
      gap: 0.4rem 0.9rem;
    }
    .conn-ed {
      grid-area: ed;
    }
    .conn-label {
      grid-area: label;
    }
    .copy-btn {
      grid-area: copy;
      justify-self: end;
    }
    .conn-val {
      grid-area: val;
    }
    .toc-row {
      grid-template-columns: 1.6rem 1fr auto;
      grid-template-areas:
        'n name count'
        'desc desc desc';
      gap: 0.35rem 0.9rem;
    }
    .toc-n {
      grid-area: n;
    }
    .toc-name {
      grid-area: name;
    }
    .toc-count {
      grid-area: count;
      text-align: right;
    }
    .toc-desc {
      grid-area: desc;
    }
    .toc-arr {
      display: none;
    }
  }
</style>
