---
import Base from '../layouts/Base.astro';
import Icon from '../components/Icon.astro';
import OriginCard from '../components/OriginCard.astro';
import { origins } from '../data/origins';
import { site } from '../data/site';

const featured = origins.slice(0, 6);

const features = [
  {
    icon: 'layers',
    title: '16 Origens únicas',
    text: 'De Humano a Dragão: cada Origem tem poderes ativos, passivas e fraquezas que mudam completamente o jogo.',
  },
  {
    icon: 'gauge',
    title: 'Progressão própria',
    text: 'Um sistema de XP separado do Minecraft. Jogue do jeito da sua Origem e suba do nível 1 ao 10, liberando bônus.',
  },
  {
    icon: 'shield',
    title: 'Java & Bedrock',
    text: 'Entre pelo PC ou pelo celular/console: o servidor aceita as duas edições no mesmo mundo.',
  },
];
---

<Base>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="chip">{site.tagline}</span>
      <h1>Escolha sua <span class="grad">Origem</span>.<br />Reescreva a sobrevivência.</h1>
      <p class="lead">{site.description}</p>
      <div class="hero-cta">
        <a class="btn btn-gold btn-lg" href="#status"><Icon name="play" size={17} /> Como entrar</a>
        <a class="btn btn-outline btn-lg" href="/origins"><Icon name="layers" size={18} /> Ver Origins</a>
      </div>
    </div>
  </section>

  <!-- Status / IP -->
  <section id="status" class="section">
    <div class="container status-card card">
      <div>
        <span class="eyebrow"><Icon name="server" size={15} /> Conecte-se</span>
        <h2 class="section-title">Entre no servidor</h2>
        <p class="section-sub">Adicione o endereço abaixo no Minecraft (Java ou Bedrock) e escolha sua Origem ao entrar.</p>
      </div>
      <div class="ip-box">
        <code id="ip">{site.ip}</code>
        <button class="btn btn-gold" id="copy-ip" type="button" aria-label="Copiar endereço">
          <Icon name="copy" size={16} /> <span>Copiar</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section">
    <div class="container">
      <span class="eyebrow"><Icon name="sparkles" size={15} /> O que torna o Feather Flux diferente</span>
      <h2 class="section-title">Não é só mais um SMP</h2>
      <div class="feature-grid">
        {
          features.map((f) => (
            <article class="feature card reveal">
              <span class="feat-icon"><Icon name={f.icon} size={22} /></span>
              <h3>{f.title}</h3>
              <p>{f.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Origins preview -->
  <section class="section">
    <div class="container">
      <div class="row-head">
        <div>
          <span class="eyebrow"><Icon name="layers" size={15} /> Origins</span>
          <h2 class="section-title">Comece por uma destas</h2>
        </div>
        <a class="btn btn-outline" href="/origins">Ver todas <Icon name="arrow-right" size={16} /></a>
      </div>
      <div class="origins-grid">
        {featured.map((o) => <OriginCard origin={o} />)}
      </div>
    </div>
  </section>

  <!-- Download -->
  <section id="download" class="section">
    <div class="container download card">
      <span class="eyebrow"><Icon name="download" size={15} /> Pronto para jogar</span>
      <h2 class="section-title">Baixe o Minecraft e conecte</h2>
      <p class="section-sub">
        Já tem o jogo? É só usar o endereço <code>{site.ip}</code>. Novo por aqui? Entre no Discord para
        tirar dúvidas e acompanhar novidades.
      </p>
      <div class="hero-cta">
        <a class="btn btn-gold btn-lg" href="#status"><Icon name="server" size={17} /> Ver endereço</a>
        <a class="btn btn-outline btn-lg" href={site.discord} target="_blank" rel="noopener">
          <Icon name="play" size={17} /> Entrar no Discord
        </a>
      </div>
    </div>
  </section>
</Base>

<script>
  const btn = document.getElementById('copy-ip');
  const ip = document.getElementById('ip');
  btn?.addEventListener('click', async () => {
    if (!ip?.textContent) return;
    try {
      await navigator.clipboard.writeText(ip.textContent.trim());
      const label = btn.querySelector('span');
      if (label) {
        const prev = label.textContent;
        label.textContent = 'Copiado!';
        setTimeout(() => (label.textContent = prev), 1600);
      }
    } catch {
      /* clipboard indisponível — ignora silenciosamente */
    }
  });
</script>

<style>
  .hero {
    position: relative;
    text-align: center;
    padding-block: clamp(2rem, 7vw, 5rem) clamp(1rem, 4vw, 2rem);
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }
  .hero h1 {
    font-size: clamp(2.4rem, 7vw, 4.4rem);
    line-height: 1.05;
  }
  .grad {
    background: linear-gradient(120deg, var(--gold-bright), var(--gold));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lead {
    color: var(--text-dim);
    font-size: clamp(1.02rem, 2.2vw, 1.2rem);
    max-width: 58ch;
  }
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
    margin-top: 0.6rem;
  }

  .status-card {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1.4rem, 4vw, 2.2rem);
  }
  .ip-box {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .ip-box code {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    letter-spacing: 0.02em;
    padding: 0.6rem 1.1rem;
    border-radius: var(--radius-sm);
    background: var(--glass-strong);
    border: 1px dashed color-mix(in srgb, var(--gold) 40%, transparent);
    color: var(--gold-bright);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
    margin-top: 1.6rem;
  }
  .feature {
    padding: 1.5rem;
  }
  .feat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    color: var(--gold);
    background: color-mix(in srgb, var(--gold) 13%, transparent);
    border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
    margin-bottom: 1rem;
  }
  .feature h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  .feature p {
    color: var(--text-dim);
    font-size: 0.95rem;
  }

  .row-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }
  .origins-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }

  .download {
    text-align: center;
    padding: clamp(1.8rem, 5vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .download .section-sub {
    margin-inline: auto;
  }
  .download code {
    color: var(--gold-bright);
    font-weight: 700;
  }
  .download .hero-cta {
    margin-top: 1.4rem;
  }

  @media (max-width: 820px) {
    .feature-grid,
    .origins-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .feature-grid,
    .origins-grid {
      grid-template-columns: 1fr;
    }
    .row-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
