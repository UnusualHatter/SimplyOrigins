---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import OriginCard from '../../components/OriginCard.astro';
import { origins, originGroups } from '../../data/origins';
---

<Base
  title="Origins"
  description="As 16 Origens jogáveis do Feather Flux: poderes, fraquezas, estilo de jogo e progressão de cada uma."
>
  <section class="container intro">
    <span class="eyebrow"><Icon name="layers" size={15} /> Catálogo</span>
    <h1 class="section-title">Todas as Origins</h1>
    <p class="section-sub">
      São {origins.length} Origens, cada uma com seu kit de poderes, fraquezas e progressão. Clique
      em uma para ver os detalhes.
    </p>

    <div class="filters" role="tablist" aria-label="Filtrar por grupo">
      <button class="filter active" data-filter="all" type="button">Todas</button>
      {
        originGroups.map((g) => (
          <button class="filter" data-filter={g} type="button">
            {g}
          </button>
        ))
      }
    </div>
  </section>

  <section class="container">
    <div class="grid" id="origins-grid">
      {origins.map((o) => <OriginCard origin={o} />)}
    </div>
    <p class="empty" id="empty" hidden>Nenhuma Origem neste grupo.</p>
  </section>
</Base>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter');
  const cards = document.querySelectorAll<HTMLElement>('#origins-grid .origin-card');
  const empty = document.getElementById('empty');

  const apply = (filter: string) => {
    let shown = 0;
    cards.forEach((card) => {
      const match = filter === 'all' || card.dataset.group === filter;
      card.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    if (empty) empty.hidden = shown !== 0;
  };

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      apply(btn.dataset.filter || 'all');
    });
  });
</script>

<style>
  .intro {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }
  .intro .section-sub {
    margin-inline: auto;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 1.6rem;
  }
  .filter {
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--text-dim);
    background: var(--glass);
    border: 1px solid var(--border);
    cursor: pointer;
    transition:
      color var(--t),
      background var(--t),
      border-color var(--t);
  }
  .filter:hover {
    color: var(--text);
    background: var(--glass-strong);
  }
  .filter.active {
    color: #1a1407;
    background: linear-gradient(135deg, var(--gold-bright), var(--gold));
    border-color: transparent;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .empty {
    text-align: center;
    color: var(--text-faint);
    padding: 2rem 0;
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
