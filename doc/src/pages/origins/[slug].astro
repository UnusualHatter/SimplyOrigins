---
import Base from '../../layouts/Base.astro';
import Stars from '../../components/Stars.astro';
import Icon from '../../components/Icon.astro';
import { origins, getAdjacentOrigins, type Origin } from '../../data/origins';

export function getStaticPaths() {
  return origins.map((o) => ({ params: { slug: o.slug }, props: { origin: o } }));
}

interface Props {
  origin: Origin;
}
const { origin } = Astro.props;
const { prev, next } = getAdjacentOrigins(origin.slug);

const difficultyLabels = ['', 'Iniciante', 'Tranquila', 'Intermediária', 'Avançada', 'Hardcore'];
const difficultyLabel = difficultyLabels[origin.difficulty];
---

<Base
  title={origin.name}
  description={`${origin.name}: ${origin.tagline} Vantagens, desvantagens e estilo de jogo no Feather Flux.`}
>
  <article class="origin" style={`--c:${origin.accent}`}>
    <div class="origin-glow" aria-hidden="true"></div>

    <div class="container page-top">
      <a href="/origins" class="back"><Icon name="arrow-left" size={16} /> Todas as Origins</a>

      <header class="origin-hero">
        <span class="big-glyph" aria-hidden="true">{origin.emoji}</span>
        <div class="headings">
          <span class="chip group-chip">{origin.group}</span>
          <h1>{origin.name}</h1>
          <p class="tagline">{origin.tagline}</p>
        </div>
      </header>

      <dl class="meta-row">
        <div class="meta">
          <dt>Categoria</dt>
          <dd>{origin.category}</dd>
        </div>
        <div class="meta">
          <dt>Dificuldade</dt>
          <dd class="meta-diff"><Stars value={origin.difficulty} /> {difficultyLabel}</dd>
        </div>
        <div class="meta">
          <dt>Estilo</dt>
          <dd>{origin.playstyle}</dd>
        </div>
        <div class="meta">
          <dt>Dieta</dt>
          <dd>{origin.diet}</dd>
        </div>
      </dl>

      <div class="cols">
        <section class="col pros card">
          <h2><Icon name="check" size={18} /> Vantagens</h2>
          <ul>
            {
              origin.pros.map((p) => (
                <li>
                  <Icon name="check" size={16} /> {p}
                </li>
              ))
            }
          </ul>
        </section>

        <section class="col cons card">
          <h2><Icon name="x" size={18} /> Desvantagens</h2>
          <ul>
            {
              origin.cons.map((c) => (
                <li>
                  <Icon name="x" size={16} /> {c}
                </li>
              ))
            }
          </ul>
        </section>
      </div>

      <section class="progression card">
        <h2><Icon name="gauge" size={18} /> Progressão</h2>
        <p class="prog-intro">
          XP separado do Minecraft. Jogue do jeito da sua Origem e suba até o nível 10. Cada
          nível libera um bônus permanente em cima do kit base.
        </p>
        <div class="prog-grid">
          <div class="prog-block">
            <h3>Como ganhar XP</h3>
            <ul>
              {
                origin.progression.objectives.map((o) => (
                  <li>
                    <Icon name="flame" size={15} /> {o}
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="prog-block">
            <h3>Recompensas por nível</h3>
            <ul>
              {
                origin.progression.unlocks.map((u) => (
                  <li>
                    <span class="chip lvl-chip">Nv {u.level}</span>
                    <span class="unlock-text">
                      <b>{u.name}</b>
                      {u.description}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </section>

      <section class="lore card">
        <h2><Icon name="sparkles" size={16} /> Lore</h2>
        <p>{origin.lore}</p>
      </section>

      <div class="origin-cta">
        <a class="btn btn-gold btn-lg" href="/#status">
          <Icon name="play" size={16} /> Jogar como {origin.name}
        </a>
        <a class="btn btn-outline btn-lg" href="/#download">
          <Icon name="download" size={18} /> Baixar Client
        </a>
      </div>

      <nav class="prev-next" aria-label="Outras Origins">
        <a href={`/origins/${prev.slug}`} class="pn" style={`--c:${prev.accent}`}>
          <Icon name="arrow-left" size={18} />
          <span><i>Anterior</i><b>{prev.emoji} {prev.name}</b></span>
        </a>
        <a href={`/origins/${next.slug}`} class="pn next" style={`--c:${next.accent}`}>
          <span><i>Próxima</i><b>{next.name} {next.emoji}</b></span>
          <Icon name="arrow-right" size={18} />
        </a>
      </nav>
    </div>
  </article>
</Base>

<style>
  .origin {
    --c: var(--gold);
    position: relative;
    overflow: hidden;
  }
  .origin-glow {
    position: absolute;
    top: 0;
    left: 50%;
    width: 900px;
    max-width: 130vw;
    height: 520px;
    transform: translateX(-50%);
    background: radial-gradient(
      60% 60% at 50% 0%,
      color-mix(in srgb, var(--c) 24%, transparent),
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }
  .container {
    position: relative;
    z-index: 1;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text-dim);
    font-weight: 500;
    margin-bottom: 2rem;
    transition: color var(--t);
  }
  .back:hover {
    color: var(--gold-bright);
  }

  .origin-hero {
    display: flex;
    align-items: center;
    gap: clamp(1.1rem, 3vw, 2rem);
    margin-bottom: 2.4rem;
  }
  .big-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(92px, 16vw, 128px);
    height: clamp(92px, 16vw, 128px);
    flex-shrink: 0;
    font-size: clamp(3rem, 8vw, 4.2rem);
    border-radius: 28px;
    background: color-mix(in srgb, var(--c) 16%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 40%, transparent);
    box-shadow: 0 0 50px color-mix(in srgb, var(--c) 30%, transparent);
  }
  .group-chip {
    color: color-mix(in srgb, var(--c) 85%, white 10%);
    border-color: color-mix(in srgb, var(--c) 38%, transparent);
    background: color-mix(in srgb, var(--c) 12%, transparent);
    margin-bottom: 0.7rem;
  }
  .headings h1 {
    font-size: clamp(2.3rem, 6vw, 3.6rem);
    line-height: 1;
  }
  .tagline {
    margin-top: 0.7rem;
    color: var(--text-dim);
    font-size: clamp(1.02rem, 2vw, 1.2rem);
    max-width: 52ch;
  }

  .meta-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.8rem;
    margin-bottom: 2.2rem;
  }
  .meta {
    padding: 1rem 1.1rem;
    border-radius: var(--radius);
    background: var(--glass);
    border: 1px solid var(--border);
  }
  .meta dt {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 0.4rem;
  }
  .meta dd {
    font-weight: 600;
    font-size: 0.98rem;
  }
  .meta-diff {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
    margin-bottom: 1.1rem;
  }
  .col {
    padding: clamp(1.3rem, 3vw, 1.8rem);
  }
  .col h2 {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1.1rem;
  }
  .col ul {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .col li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    color: var(--text);
    font-size: 0.98rem;
  }
  .col li :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .pros h2,
  .pros li :global(svg) {
    color: var(--green);
  }
  .cons h2,
  .cons li :global(svg) {
    color: var(--coral);
  }

  .progression {
    padding: clamp(1.3rem, 3vw, 1.8rem);
    margin-bottom: 1.1rem;
  }
  .progression h2 {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.9rem;
    color: var(--gold);
  }
  .prog-intro {
    color: var(--text-dim);
    font-size: 0.96rem;
    line-height: 1.6;
    max-width: 70ch;
    margin-bottom: 1.4rem;
  }
  .prog-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.6rem;
  }
  .prog-block h3 {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 0.9rem;
  }
  .prog-block ul {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .prog-block li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.95rem;
    color: var(--text);
  }
  .prog-block li :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--c);
  }
  .lvl-chip {
    flex-shrink: 0;
    color: color-mix(in srgb, var(--c) 85%, white 10%);
    border-color: color-mix(in srgb, var(--c) 38%, transparent);
    background: color-mix(in srgb, var(--c) 12%, transparent);
  }
  .unlock-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .unlock-text b {
    font-weight: 600;
  }

  .lore {
    padding: clamp(1.3rem, 3vw, 1.8rem);
    margin-bottom: 2.2rem;
  }
  .lore h2 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }
  .lore p {
    font-size: 1.06rem;
    line-height: 1.7;
    color: var(--text);
    max-width: 70ch;
  }

  .origin-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 2.6rem;
  }

  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .pn {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 1.2rem;
    border-radius: var(--radius);
    background: var(--glass);
    border: 1px solid var(--border);
    color: var(--text);
    transition:
      border-color var(--t),
      background var(--t),
      transform var(--t);
  }
  .pn:hover {
    border-color: color-mix(in srgb, var(--c) 55%, transparent);
    background: var(--glass-strong);
  }
  .pn.next {
    justify-content: flex-end;
    text-align: right;
  }
  .pn :global(svg) {
    color: var(--c);
    flex-shrink: 0;
  }
  .pn span {
    display: flex;
    flex-direction: column;
    line-height: 1.3;
  }
  .pn i {
    font-style: normal;
    font-size: 0.74rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .pn b {
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .meta-row {
      grid-template-columns: 1fr 1fr;
    }
    .cols {
      grid-template-columns: 1fr;
    }
    .prog-grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
  }
  @media (max-width: 480px) {
    .origin-hero {
      flex-direction: column;
      text-align: center;
      align-items: center;
    }
    .tagline {
      margin-inline: auto;
    }
  }
</style>
