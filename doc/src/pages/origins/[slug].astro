---
import Base from '../../layouts/Base.astro';
import Stars from '../../components/Stars.astro';
import Icon from '../../components/Icon.astro';
import { origins, getAdjacentOrigins, originCode, type Origin } from '../../data/origins';

export function getStaticPaths() {
  return origins.map((o) => ({ params: { slug: o.slug }, props: { origin: o } }));
}

interface Props {
  origin: Origin;
}
const { origin } = Astro.props;
const { prev, next } = getAdjacentOrigins(origin.slug);
const code = originCode(origin);

const difficultyLabels = ['', 'Iniciante', 'Tranquila', 'Intermediária', 'Avançada', 'Hardcore'];
const difficultyLabel = difficultyLabels[origin.difficulty];

const specs = [
  { k: 'Categoria', v: origin.category },
  { k: 'Grupo', v: origin.group },
  { k: 'Estilo', v: origin.playstyle },
  { k: 'Dieta', v: origin.diet },
];
---

<Base
  title={origin.name}
  description={`${origin.name}: ${origin.tagline} Vantagens, desvantagens e estilo de jogo no Feather Flux.`}
>
  <article class="origin" style={`--c:${origin.accent}`}>
    <div class="container">
      <a href="/wiki/origens" class="back"><Icon name="arrow-left" size={14} /> Origens</a>

      <header class="o-hero">
        <span class="o-code">{code}</span>
        <div class="o-id">
          <span class="o-glyph" aria-hidden="true">{origin.emoji}</span>
          <div class="o-headings">
            <h1>{origin.name}</h1>
            <p class="o-tag">{origin.tagline}</p>
          </div>
        </div>
      </header>

      <dl class="spec">
        {
          specs.map((s) => (
            <div class="spec-cell">
              <dt>{s.k}</dt>
              <dd>{s.v}</dd>
            </div>
          ))
        }
        <div class="spec-cell">
          <dt>Dificuldade</dt>
          <dd class="spec-diff"><Stars value={origin.difficulty} /> <span>{difficultyLabel}</span></dd>
        </div>
      </dl>

      <div class="po-cols">
        <section class="po-col">
          <div class="section-label" style="--sq: var(--green)">
            <span class="sq"></span>
            <h2>Vantagens</h2>
            <span class="count">{origin.pros.length}</span>
          </div>
          <ul class="po-list">
            {origin.pros.map((p) => (
              <li><span class="mk pos">+</span>{p}</li>
            ))}
          </ul>
        </section>

        <section class="po-col">
          <div class="section-label" style="--sq: var(--red)">
            <span class="sq"></span>
            <h2>Desvantagens</h2>
            <span class="count">{origin.cons.length}</span>
          </div>
          <ul class="po-list">
            {origin.cons.map((c) => (
              <li><span class="mk neg">−</span>{c}</li>
            ))}
          </ul>
        </section>
      </div>

      <section class="prog">
        <div class="section-label">
          <span class="sq"></span>
          <h2>Progressão</h2>
          <span class="count">Nível 1 → 10</span>
        </div>
        <p class="prog-intro">
          É um XP separado do Minecraft. Jogue do jeito da sua origem e suba até o nível 10. Cada
          nível dá um bônus permanente que vai somando com o resto.
        </p>
        <div class="prog-cols">
          <div class="prog-block">
            <h3>Como ganhar XP</h3>
            <ul class="prog-objs">
              {origin.progression.objectives.map((o) => (
                <li><span class="b">›</span>{o}</li>
              ))}
            </ul>
          </div>
          <div class="prog-block">
            <h3>Recompensas por nível</h3>
            <ul class="prog-unlocks">
              {origin.progression.unlocks.map((u) => (
                <li>
                  <span class="lvl">Nv {u.level}</span>
                  <span class="utext"><b>{u.name}</b> {u.description}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="lore">
        <div class="section-label">
          <span class="sq"></span>
          <h2>Lore</h2>
        </div>
        <p>{origin.lore}</p>
      </section>

      <div class="o-actions">
        <a class="btn btn-primary" href="/"><Icon name="play" size={14} /> Como entrar</a>
        <a class="btn" href="/wiki/origens">Ver todas as origens</a>
      </div>

      <nav class="prev-next" aria-label="Outras origens">
        <a href={`/origins/${prev.slug}`} class="pn">
          <Icon name="arrow-left" size={16} />
          <span>
            <i>{originCode(prev)}</i>
            <b>{prev.emoji} {prev.name}</b>
          </span>
        </a>
        <a href={`/origins/${next.slug}`} class="pn next">
          <span>
            <i>{originCode(next)}</i>
            <b>{next.name} {next.emoji}</b>
          </span>
          <Icon name="arrow-right" size={16} />
        </a>
      </nav>
    </div>
  </article>
</Base>

<style>
  .origin {
    --c: var(--gold);
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.03em;
    color: var(--text-faint);
    margin-bottom: 1.75rem;
    transition: color var(--t);
  }
  .back:hover {
    color: var(--gold-bright);
  }

  /* ---- Hero ---- */
  .o-hero {
    border-top: 2px solid var(--c);
    padding-top: 1.4rem;
    margin-bottom: 1.75rem;
  }
  .o-code {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }
  .o-id {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    margin-top: 0.9rem;
  }
  .o-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(64px, 12vw, 84px);
    height: clamp(64px, 12vw, 84px);
    flex: none;
    font-size: clamp(2rem, 6vw, 2.8rem);
    border: 1px solid color-mix(in srgb, var(--c) 45%, var(--line-2));
    background: var(--panel);
  }
  .o-headings h1 {
    font-size: clamp(1.9rem, 5vw, 2.9rem);
    letter-spacing: -0.02em;
  }
  .o-tag {
    margin-top: 0.5rem;
    color: var(--text-dim);
    font-size: clamp(0.98rem, 2vw, 1.12rem);
    max-width: 54ch;
    line-height: 1.5;
  }

  /* ---- Spec grid ---- */
  .spec {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border: 1px solid var(--line);
    border-left: 0;
    margin-bottom: 2.25rem;
  }
  .spec-cell {
    padding: 0.85rem 0.95rem;
    border-left: 1px solid var(--line);
  }
  .spec dt {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-mute);
    margin-bottom: 0.4rem;
  }
  .spec dd {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
  }
  .spec-diff {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .spec-diff span {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  /* ---- Pros / cons ---- */
  .po-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2.5rem;
    margin-bottom: 2.25rem;
  }
  .po-col .section-label {
    margin-top: 0;
  }
  .po-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .po-list li {
    display: flex;
    gap: 0.65rem;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--text);
  }
  .mk {
    font-family: var(--font-mono);
    font-weight: 600;
    flex: none;
    width: 0.9rem;
  }
  .mk.pos {
    color: var(--green);
  }
  .mk.neg {
    color: var(--red);
  }

  /* ---- Progression ---- */
  .prog {
    margin-bottom: 2.25rem;
  }
  .prog-intro {
    color: var(--text-dim);
    font-size: 0.92rem;
    line-height: 1.6;
    max-width: 72ch;
    margin-bottom: 1.5rem;
  }
  .prog-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2.5rem;
  }
  .prog-block h3 {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 0.9rem;
  }
  .prog-objs {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .prog-objs li {
    display: flex;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.5;
  }
  .prog-objs .b {
    font-family: var(--font-mono);
    color: var(--c);
    flex: none;
  }
  .prog-unlocks {
    display: flex;
    flex-direction: column;
  }
  .prog-unlocks li {
    display: flex;
    gap: 0.8rem;
    padding: 0.7rem 0;
    border-top: 1px solid var(--line);
  }
  .prog-unlocks li:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .lvl {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.03em;
    color: var(--gold);
    border: 1px solid var(--gold-dim);
    padding: 0.18rem 0.4rem;
    height: max-content;
    white-space: nowrap;
    flex: none;
  }
  .utext {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.5;
  }
  .utext b {
    color: var(--text);
    font-weight: 600;
  }

  /* ---- Lore ---- */
  .lore {
    margin-bottom: 2.25rem;
  }
  .lore p {
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--text);
    max-width: 72ch;
    padding-left: 1rem;
    border-left: 2px solid var(--line-2);
  }

  /* ---- Actions ---- */
  .o-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: 2.5rem;
  }

  /* ---- Prev / next ---- */
  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 1px solid var(--line);
    border-top: 1px solid var(--line);
  }
  .pn {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 1.1rem;
    color: var(--text);
    transition:
      background var(--t),
      color var(--t);
  }
  .pn + .pn {
    border-left: 1px solid var(--line);
  }
  .pn:hover {
    background: var(--panel-2);
  }
  .pn.next {
    justify-content: flex-end;
    text-align: right;
  }
  .pn :global(svg) {
    color: var(--text-mute);
    flex: none;
    transition: color var(--t);
  }
  .pn:hover :global(svg) {
    color: var(--gold);
  }
  .pn span {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }
  .pn i {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: var(--text-mute);
  }
  .pn b {
    font-weight: 500;
    font-size: 0.95rem;
  }

  @media (max-width: 760px) {
    .spec {
      grid-template-columns: 1fr 1fr;
      border-top: 0;
    }
    .spec-cell {
      border-top: 1px solid var(--line);
    }
    .po-cols,
    .prog-cols {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }
  }
  @media (max-width: 460px) {
    .spec {
      grid-template-columns: 1fr;
    }
  }
</style>
